# LLM endpoint — use vLLM URL or https://api.openai.com/v1
OPENAI_BASE_URL=http://<gpu-private-ip>:8000/v1
# API key — use any string for vLLM, real key for OpenAI
OPENAI_API_KEY=not-needed

# Langfuse tracing — optional; tracing disabled if absent
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000
