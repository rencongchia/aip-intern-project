# Copy to .env and fill in your values
OPENAI_BASE_URL=http://your-vllm-endpoint:8000/v1
OPENAI_API_KEY=not-needed-for-vllm
OPENAI_MODEL=Qwen/Qwen3-32B-Instruct

# Optional: Langfuse tracing (disabled if LANGFUSE_SECRET_KEY is absent)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000
